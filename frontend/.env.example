# Sin estas variables (o con AUTH_DISABLED=true), la app corre en MODO DEMO
# (mock local fiel al contrato). Copiar como .env.local y completar.

# Backend FastAPI — arrancar con: cd backend && uvicorn main:app --reload
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth (browser)
# https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# IMPORTANTE: usá la clave anon / publishable. NUNCA la service_role en el frontend.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...TU_ANON_KEY

# true = saltar login/gate (demo). false = exigir Supabase Auth.
# Si no hay URL/anon key, auth queda deshabilitado automáticamente.
NEXT_PUBLIC_AUTH_DISABLED=true
