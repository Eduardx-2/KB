# =============================================================================
# Backend FastAPI — environment template (NO secrets)
# Copy to backend/.env and fill in real values.
# =============================================================================

# --- Required ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth / SaaS ---
# Demo mode: skip JWT, use X-Team-Id or DEFAULT_TEAM_ID as tenant.
AUTH_DISABLED=true
# JWT secret from Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=
# Demo team UUID (seed: 00000000-0000-0000-0000-000000000001)
DEFAULT_TEAM_ID=00000000-0000-0000-0000-000000000001

# --- CORS ---
# "*" for local demo, or comma-separated origins in production:
# CORS_ORIGINS=https://app.example.com,http://localhost:3000
CORS_ORIGINS=*

# --- Rate limits / uploads ---
RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_BYTES=25000000

# --- Environment ---
ENVIRONMENT=development
APP_VERSION=v2

# --- Optional integrations ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v1
STT_LANGUAGE=es
N8N_WEBHOOK_URL=
# If set, backend sends X-Webhook-Secret on n8n POSTs
N8N_WEBHOOK_SECRET=

# --- Stripe (optional; stubs return 501 when STRIPE_SECRET_KEY is empty) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
